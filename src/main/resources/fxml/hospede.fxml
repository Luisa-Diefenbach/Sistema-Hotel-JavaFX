<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisa.hotel.controller.HospedeController">

    <children>

        <Label text="Cadastro de Hóspedes" />

        <TextField fx:id="txtNome" promptText="Nome" />

        <TextField fx:id="txtCpf" promptText="CPF" />

        <TextField fx:id="txtTelefone" promptText="Telefone" />

        <TextField fx:id="txtEmail" promptText="Email" />

        <HBox alignment="CENTER" spacing="10">

            <children>
            <Button fx:id="btnSalvar" mnemonicParsing="false" onAction="#salvarHospede" text="Salvar" />

                <Button fx:id="btnAtualizar" onAction="#atualizarHospede" text="Atualizar" />

                <Button fx:id="btnExcluir" onAction="#excluirHospede" text="Excluir" />

                <Button fx:id="btnListar" onAction="#listarHospedes" text="Listar" />
            <Button fx:id="btnMenu" mnemonicParsing="false" onAction="#voltarMenu" text="Menu" />

            </children>

        </HBox>

        <TableView fx:id="tbHospedes" prefHeight="200" prefWidth="500">

            <columns>

                <TableColumn fx:id="colNome" prefWidth="120" text="Nome" />

                <TableColumn fx:id="colCpf" prefWidth="120" text="CPF" />

                <TableColumn fx:id="colTelefone" prefWidth="120" text="Telefone" />

                <TableColumn fx:id="colEmail" prefWidth="120" text="Email" />

            </columns>

        </TableView>

    </children>

</VBox>
