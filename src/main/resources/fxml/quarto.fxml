<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisa.hotel.controller.QuartoController">

    <children>

        <Label text="Cadastro de Quartos" />

        <TextField fx:id="txtNumero" promptText="Número do Quarto" />

        <TextField fx:id="txtTipo" promptText="Tipo (Single, Double ou Luxury)" />

        <TextField fx:id="txtValorDiaria" promptText="Valor da Diária" />

        <TextField fx:id="txtStatus" promptText="Status (DISPONIVEL/OCUPADO)" />

        <HBox alignment="CENTER" spacing="10">

            <children>

                <Button fx:id="btnSalvar" onAction="#salvarQuarto" text="Salvar" />

                <Button fx:id="btnAtualizar" onAction="#atualizarQuarto" text="Atualizar" />

                <Button fx:id="btnExcluir" onAction="#excluirQuarto" text="Excluir" />

                <Button fx:id="btnListar" onAction="#listarQuartos" text="Listar" />
            <Button fx:id="btnMenu" mnemonicParsing="false" onAction="#voltarMenu" text="Menu" />

            </children>

        </HBox>

        <TableView fx:id="tbQuartos" prefHeight="200" prefWidth="500">

            <columns>

                <TableColumn fx:id="colNumero" prefWidth="120" text="Número" />

                <TableColumn fx:id="colTipo" prefWidth="120" text="Tipo" />

                <TableColumn fx:id="colValorDiaria" prefWidth="120" text="Diária" />

                <TableColumn fx:id="colStatus" prefWidth="120" text="Status" />

            </columns>

        </TableView>

    </children>

</VBox>
